{
  "name": "LearnCS",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check && tsc --noEmit",
    "lint": "eslint -c config/eslint.config.cjs src/**/*.{ts,tsx,astro} --max-warnings 0",
    "format": "prettier --config config/prettier.config.mjs --write \"src/**/*.{ts,tsx,astro,mdx}\" \"modules/**/*.{mdx,json}\"",
    "knip": "knip --config config/knip.json"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/react": "^3.6.3",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "astro": "^4.16.19",
    "fuse.js": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.31.4",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fuse.js": "^7.0.0",
    "knip": "^5.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.12"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}